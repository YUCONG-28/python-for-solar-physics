# ============================================================
# Python 标准忽略规则
# ============================================================

# 环境变量和配置文件
.env
.env.*
!.env.example
config.json
secrets.json
configs/paths.local.yaml

# Python 缓存和编译文件
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# 备份文件和压缩包
backup_*/
*.bak
*.bak_*
*~
\#*#
.#*

# IDE 和编辑器文件
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
Desktop.ini

# 日志文件
*.log
logs/

# 数据分析临时文件
*.npy
*.npz
*.pickle
*.pkl
*.nc
*.cdf
*.jp2
*.h5
*.hdf5
*.feather
*.parquet

# Streamlit 缓存
.static/
.streamlit/

# 临时文件
temp/
tmp/
.automated-tool*
.automated-tool.chat.history.md

# ============================================================
# 太阳物理项目特定忽略规则
# ============================================================

# FITS 文件（通常很大）
*.fits
*.fits.gz
*.fits.fz

# 天文数据目录
data/raw/
data/processed/
observations/

# 大型输出文件
output/plots/
outputs/generated/
plots/
video/
videos/

# ============================================================
# 生成的可视化输出图片（可由脚本重新生成）
# ============================================================
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tiff
*.tif
*.mp4
*.mov
*.avi
*.mkv

# ============================================================
# 数据/表格文件（非代码源文件）
# ============================================================
*.xlsx
*.xls
*.csv
*.db
*.sqlite
*.sqlite3

# ============================================================
# Jupyter 笔记本检查点
# ============================================================
.ipynb_checkpoints/

# ============================================================
# Python 虚拟环境
# ============================================================
venv/
env/
.venv/
ENV/

